# ============================================================
#  Fankar Protocol — Root .gitignore
#  Covers: frontend (Next.js) · backend (Python/FastAPI) · web3-contracts (Hardhat)
# ============================================================

# ── Secrets (CRITICAL — never commit) ────────────────────────
.env
.env.local
.env.*.local
.env.production
backend/.env
frontend/.env.local
web3-contracts/.env

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/
.Python

# ── Virtual Environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Node / npm ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnp.*

# ── Next.js ──────────────────────────────────────────────────
.next/
out/
.vercel
*.tsbuildinfo
next-env.d.ts

# ── Hardhat / Solidity ────────────────────────────────────────
web3-contracts/artifacts/
web3-contracts/cache/
web3-contracts/typechain-types/

# ── OS & IDE ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Misc uploads / IPFS cache ────────────────────────────────
backend/uploads/
backend/metadata/
