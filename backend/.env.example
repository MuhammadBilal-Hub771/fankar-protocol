# ==============================================================
#  Fankar AI Service — Environment Variables
#  ──────────────────────────────────────────
#  1. Copy this file:   cp .env.example .env
#  2. Fill in ALL values before running the server.
#  3. NEVER commit the real .env file to version control.
# ==============================================================

# ── Blockchain Signing ─────────────────────────────────────
# Private key of the AI signer wallet.
# This key matches the aiSigner address stored in FankarNFT.sol.
# ⚠️  Keep this strictly on the backend server — never expose it.
AI_SIGNER_PRIVATE_KEY=0xYOUR_AI_SIGNER_PRIVATE_KEY_HERE

# Deployed FankarNFT contract address on WireFluid.
CONTRACT_ADDRESS=0xYOUR_FANKAR_NFT_CONTRACT_ADDRESS_HERE

# WireFluid EVM Chain ID
CHAIN_ID=92533

# ── Pinata IPFS ────────────────────────────────────────────
# Generate API keys at: https://app.pinata.cloud/developers/api-keys
PINATA_API_KEY=YOUR_PINATA_API_KEY_HERE
PINATA_API_SECRET=YOUR_PINATA_API_SECRET_HERE

# ── Server ─────────────────────────────────────────────────
# Host and port for uvicorn (optional, defaults shown)
HOST=0.0.0.0
PORT=8000
