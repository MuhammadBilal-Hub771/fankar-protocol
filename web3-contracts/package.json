{
  "name": "fankar-protocol-contracts",
  "version": "1.0.0",
  "description": "Fankar Protocol smart contracts — deployed on WireFluid EVM (Chain ID: 92533)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "deploy:wirefluid": "hardhat --network wirefluid run scripts/deploy.ts",
    "deploy:local": "hardhat --network localhost run scripts/deploy.ts",
    "update-signer": "hardhat --network wirefluid run scripts/update-signer.ts",
    "test": "hardhat test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "hardhat": "^3.3.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^16.0.0",
    "viem": "^2.0.0"
  }
}
