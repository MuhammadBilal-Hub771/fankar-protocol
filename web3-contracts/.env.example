# ==============================================================
#  Fankar Protocol — Environment Variables
#  ──────────────────────────────────────
#  1. Copy this file:   cp .env.example .env
#  2. Fill in ALL values before running any Hardhat script.
#  3. NEVER commit the real .env file to version control.
#     (It is already listed in .gitignore)
# ==============================================================


# ── Deployer Wallet ────────────────────────────────────────
#  The private key of the wallet that will pay gas and deploy
#  the FankarNFT contract on WireFluid.
#  Format: 64 hex characters with 0x prefix.
#  Example: 0xabc123...  (DO NOT use a wallet with real funds on mainnet for testing)
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HERE


# ── AI Backend Signer ──────────────────────────────────────
#  The *public address* (NOT private key) of the Fankar AI backend
#  signing wallet.  This address is stored in the contract as
#  `aiSigner` and every mint must carry a valid ECDSA signature
#  from the corresponding private key.
#
#  The corresponding private key (AI_SIGNER_KEY below) is kept
#  exclusively on the Fankar backend server — never on-chain.
#
#  Format: EVM address with 0x prefix.
AI_SIGNER_ADDRESS=0xYOUR_AI_SIGNER_PUBLIC_ADDRESS_HERE


# ── AI Signer Private Key (Backend Server Only) ───────────
#  The private key used by the Fankar AI backend to sign mint
#  authorisation messages.
#
#  ⚠️  SECURITY CRITICAL — This key MUST stay on the backend
#     server.  It should NEVER be included in the frontend,
#     committed to git, or shared publicly.
#
#  This key is NOT used in the deployment script — it is only
#  needed by the off-chain AI service that issues mint permits.
AI_SIGNER_KEY=0xYOUR_AI_SIGNER_PRIVATE_KEY_HERE


# ── Protocol Treasury ──────────────────────────────────────
#  EVM address of the Fankar Protocol treasury wallet.
#  This address receives 15 % of every mint fee and
#  secondary-sale royalty distribution.
TREASURY_ADDRESS=0xYOUR_TREASURY_WALLET_ADDRESS_HERE


# ── Deployed Contract (filled AFTER deployment) ───────────
#  Copy the address printed by scripts/deploy.ts here so that
#  other scripts and the backend can reference it.
CONTRACT_ADDRESS=


# ── WireFluid Network ──────────────────────────────────────
#  These are public values — safe to commit if needed.
#  Listed here for reference and for any scripts that
#  need to construct RPC clients dynamically.
WIREFLUID_RPC_URL=https://evm.wirefluid.com
WIREFLUID_CHAIN_ID=92533
WIREFLUID_CURRENCY=WIRE
